@page "/staff-profile/{staffId:int}"
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<div class="dash-page">
    <div class="bg-shapes">
        <div class="bg-shape bg-s1"></div>
        <div class="bg-shape bg-s2"></div>
        <div class="bg-shape bg-s3"></div>
    </div>

    <!-- TOP NAVBAR -->
    <div class="dash-navbar">
        <div class="navbar-left">
            <button class="hamburger-btn" @onclick="ToggleDrawer">
                <MudIcon Icon="@Icons.Material.Filled.Menu" Class="hamburger-icon" />
            </button>
            <img src="aclc_logo.png" alt="ACLC Logo" class="nav-logo" />
            <span class="nav-brand">School Clearance</span>
        </div>
        <div class="navbar-center">
            <div class="search-wrapper">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
                <input placeholder="Search staff..." class="search-input" />
            </div>
        </div>
        <div class="navbar-right">
            <div class="nav-avatar" @onclick="ToggleProfileMenu">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="avatar-icon" />
            </div>
            @if (showProfileMenu)
            {
                <div style="position:fixed;inset:0;z-index:99;" @onclick="() => showProfileMenu = false"></div>
                <div class="profile-dropdown" style="z-index:100;">
                    <div class="profile-menu-item" @onclick="GoToProfile">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="profile-menu-icon" />
                        <span>Profile</span>
                    </div>
                    <div class="profile-menu-divider"></div>
                    <div class="profile-menu-item logout" @onclick="HandleLogout">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Class="profile-menu-icon" />
                        <span>Logout</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- DRAWER OVERLAY -->
    @if (drawerOpen)
    {
        <div class="drawer-overlay" @onclick="CloseDrawer"></div>
    }

    <!-- SIDE DRAWER -->
    <div class="side-drawer @(drawerOpen ? "drawer-open" : "")">
        <div class="drawer-header">
            <img src="aclc_logo.png" alt="ACLC Logo" class="drawer-logo" />
            <div class="drawer-brand-wrap">
                <span class="drawer-brand">School Clearance</span>
                <span class="drawer-sub">Student Portal</span>
            </div>
            <button class="drawer-close-btn" @onclick="CloseDrawer">
                <MudIcon Icon="@Icons.Material.Filled.Close" Class="drawer-close-icon" />
            </button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/dashboard")'>
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="drawer-nav-icon" />
                <span>Dashboard</span>
            </div>
            <div class="drawer-section-label">OFFICES</div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/registrar")'>
                <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Class="drawer-nav-icon" />
                <span>Registrar Office</span>
            </div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/cashier")'>
                <MudIcon Icon="@Icons.Material.Filled.Payments" Class="drawer-nav-icon" />
                <span>Cashier Office</span>
            </div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/grade-release")'>
                <MudIcon Icon="@Icons.Material.Filled.Grade" Class="drawer-nav-icon" />
                <span>Grade Release</span>
            </div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/announcements")'>
                <MudIcon Icon="@Icons.Material.Filled.Campaign" Class="drawer-nav-icon" />
                <span>Announcements</span>
            </div>
            <div class="drawer-section-label">ACCOUNT</div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/settings")'>
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="drawer-nav-icon" />
                <span>Settings</span>
            </div>
        </nav>
    </div>

    <!-- PAGE CONTENT -->
    <div class="dash-content">

        @if (isLoading)
        {
            <div class="loading-wrapper">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                <MudText Typo="Typo.body1" Class="loading-text">Loading staff profile...</MudText>
            </div>
        }
        else if (staff == null)
        {
            <div class="glass-card">
                <div class="empty-state">
                    <MudIcon Icon="@Icons.Material.Filled.PersonOff" Class="empty-icon" />
                    <span class="empty-text">Staff member not found.</span>
                    <button class="back-btn-inline" @onclick='() => Navigation.NavigateTo("/dashboard")'>
                        Go back to Dashboard
                    </button>
                </div>
            </div>
        }
        else
        {
            <!-- PROFILE HEADER CARD -->
            <div class="profile-header-card">
                <!-- Cover Banner -->
                <div class="profile-cover-banner"></div>

                <!-- Avatar + Info -->
                <div class="profile-header-body">
                    <div class="profile-avatar-circle">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="profile-avatar-icon" />
                    </div>
                    <div class="profile-header-info">
                        <span class="profile-fullname">@staff.FullName</span>
                        <span class="profile-position-dept">@staff.Position &bull; @staff.Department</span>
                        <div class="profile-header-badges">
                            <span class="staff-status-chip @GetStaffStatusClass(staff.StaffStatus)">
                                <span class="status-dot-inline @GetStaffStatusDotClass(staff.StaffStatus)"></span>
                                @staff.StaffStatus
                            </span>
                            @if (IsOfficePosition(staff.Position))
                            {
                                <span class="office-status-chip @GetOfficeStatusClass(staff.OfficeStatus)">
                                    <MudIcon Icon="@GetOfficeStatusIcon(staff.OfficeStatus)" Class="chip-icon" />
                                    @staff.OfficeStatus
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- INFO CARD -->
            <div class="glass-card">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Class="section-icon" />
                    <MudText Typo="Typo.subtitle1" Class="section-label">STAFF INFORMATION</MudText>
                </div>

                <div class="info-rows">
                    <!-- Location -->
                    <div class="info-row">
                        <div class="info-icon-wrap">
                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Class="info-row-icon" />
                        </div>
                        <div class="info-row-content">
                            <span class="info-row-label">Current Location</span>
                            <span class="info-row-value">
                                @(string.IsNullOrEmpty(staff.CurrentLocation) ? "No location set" : staff.CurrentLocation)
                            </span>
                        </div>
                    </div>

                    <!-- Department -->
                    <div class="info-row">
                        <div class="info-icon-wrap">
                            <MudIcon Icon="@Icons.Material.Filled.Business" Class="info-row-icon" />
                        </div>
                        <div class="info-row-content">
                            <span class="info-row-label">Department</span>
                            <span class="info-row-value">@staff.Department</span>
                        </div>
                    </div>

                    <!-- Position -->
                    <div class="info-row">
                        <div class="info-icon-wrap">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Class="info-row-icon" />
                        </div>
                        <div class="info-row-content">
                            <span class="info-row-label">Position</span>
                            <span class="info-row-value">@staff.Position</span>
                        </div>
                    </div>
                </div>

                <!-- OFFICE STATUS SECTION (only for Registrar, Cashier, Grade Release) -->
                @if (IsOfficePosition(staff.Position))
                {
                    <div class="office-status-section">
                        <div class="office-section-divider">
                            <MudIcon Icon="@Icons.Material.Filled.Storefront" Class="office-section-icon" />
                            <span class="office-section-title">OFFICE STATUS</span>
                        </div>

                        <div class="office-badges-row">
                            <div class="office-badge-wrap">
                                <span class="badge-label">Office</span>
                                <span class="office-status-badge @GetOfficeStatusClass(staff.OfficeStatus)">
                                    <MudIcon Icon="@GetOfficeStatusIcon(staff.OfficeStatus)" Class="badge-icon" />
                                    @staff.OfficeStatus
                                </span>
                            </div>
                            <div class="office-badge-wrap">
                                <span class="badge-label">Crowd</span>
                                <span class="crowd-status-badge @GetCrowdStatusClass(staff.CrowdStatus)">
                                    @GetCrowdStatusEmoji(staff.CrowdStatus) @GetCrowdStatusLabel(staff.CrowdStatus)
                                </span>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(staff.StaffNote))
                        {
                            <div class="office-note-row">
                                <MudIcon Icon="@Icons.Material.Filled.StickyNote2" Class="note-icon" />
                                <span class="office-note-text">@staff.StaffNote</span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(staff.AcceptanceWindow))
                        {
                            <div class="office-window-row">
                                <MudIcon Icon="@Icons.Material.Filled.AccessTime" Class="window-icon" />
                                <div>
                                    <span class="window-label">Acceptance Window</span>
                                    <span class="window-value">@staff.AcceptanceWindow</span>
                                </div>
                            </div>
                        }

                        @if (staff.LastUpdatedAt.HasValue)
                        {
                            <div class="last-updated-row">
                                <MudIcon Icon="@Icons.Material.Filled.Update" Class="updated-icon" />
                                <span class="last-updated-text">Last updated: @GetTimeAgo(staff.LastUpdatedAt.Value)</span>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- POSTS CARD -->
            <div class="glass-card">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.Article" Class="section-icon" />
                    <MudText Typo="Typo.subtitle1" Class="section-label">ANNOUNCEMENTS</MudText>
                    @if (posts.Count > 0)
                    {
                        <span class="posts-count-badge">@posts.Count</span>
                    }
                </div>

                @if (posts.Count == 0)
                {
                    <div class="empty-state">
                        <MudIcon Icon="@Icons.Material.Outlined.Article" Class="empty-icon" />
                        <span class="empty-text">No posts yet from this staff member.</span>
                    </div>
                }
                else
                {
                    <div class="posts-list">
                        @foreach (var post in posts)
                        {
                            <div class="post-card">
                                <div class="post-header">
                                    <span class="post-title">@post.Title</span>
                                    <span class="post-date">@post.PostedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                                <p class="post-content">@post.Content</p>
                            </div>
                        }
                    </div>
                }
            </div>
        }

    </div>
</div>

@code {
    [Parameter] public int StaffId { get; set; }

    private bool drawerOpen = false;
    private bool showProfileMenu = false;
    private bool isLoading = true;

    private StaffListModel? staff = null;
    private List<StaffPostModel> posts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            await Task.Delay(600); // ⚠️ MOCK DATA — replace with StaffService.GetStaffById + GetPostsByStaff

            // ⚠️ MOCK DATA
            var allStaff = new List<StaffListModel>
            {
              new StaffListModel
                {
                    StaffId = 1,
                    FullName = "Maria Santos",
                    Position = "Registrar",
                    Department = "College",
                    CurrentLocation = "Room 101, Main Building",
                    StaffStatus = "Available",
                    OfficeStatus = "Open",
                    CrowdStatus = "Busy",
                    StaffNote = "Please bring your student ID and enrollment form.",
                    AcceptanceWindow = "8:00 AM – 12:00 PM, 1:00 PM – 5:00 PM",
                    LastUpdatedAt = DateTime.Now.AddMinutes(-15)
                },
                new StaffListModel
                {
                    StaffId = 2,
                    FullName = "Jose Reyes",
                    Position = "Registrar",
                    Department = "Senior High School",
                    CurrentLocation = "Room 102, Main Building",
                    StaffStatus = "On Break",
                    OfficeStatus = "Open",
                    CrowdStatus = "Open",
                    StaffNote = null,
                    AcceptanceWindow = null,
                    LastUpdatedAt = DateTime.Now.AddMinutes(-30)
                },
                new StaffListModel
                {
                    StaffId = 3,
                    FullName = "Ana Lim",
                    Position = "Registrar",
                    Department = "College",
                    CurrentLocation = null,
                    StaffStatus = "Absent",
                    OfficeStatus = "Closed",
                    CrowdStatus = "Open",
                    StaffNote = null,
                    AcceptanceWindow = null,
                    LastUpdatedAt = DateTime.Now.AddHours(-2)
                }
            };

            staff = allStaff.FirstOrDefault(s => s.StaffId == StaffId);

            // ⚠️ MOCK POSTS
            var allPosts = new List<StaffPostModel>
            {
                new StaffPostModel
                {
                    PostId = 1,
                    StaffId = 1,
                    FullName = "Maria Santos",
                    Position = "Registrar",
                    Title = "Clearance Requirements Reminder",
                    Content = "Please make sure to bring your original enrollment form, 2x2 photos, and valid school ID when processing your clearance. Incomplete requirements will not be accepted.",
                    PostedAt = DateTime.Now.AddDays(-2)
                },
                new StaffPostModel
                {
                    PostId = 2,
                    StaffId = 2,
                    FullName = "Jose Reyes",
                    Position = "Registrar",
                    Title = "Office Hours Update",
                    Content = "Starting next week, the Registrar office will be open from 8:00 AM to 5:00 PM with a lunch break from 12:00 PM to 1:00 PM. No transactions after 4:30 PM.",
                    PostedAt = DateTime.Now.AddDays(-5)
                },
                new StaffPostModel
                {
                    PostId = 3,
                    StaffId = 3,
                    FullName = "Ana Lim",
                    Position = "Cashier",
                    Title = "Payment Deadline",
                    Content = "All outstanding balances must be settled before clearance can be processed. Please bring official receipts for previously paid fees.",
                    PostedAt = DateTime.Now.AddDays(-1)
                }
            };

            posts = allPosts.Where(p => p.StaffId == StaffId).ToList();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load staff profile. Please try again.", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    // ── Helpers ──────────────────────────────────────────

    private bool IsOfficePosition(string position) =>
        position == "Registrar" || position == "Cashier" || position == "Grade Release";

    private string GetStaffStatusClass(string status) => status switch
    {
        "Available" => "chip-available",
        "On Break" => "chip-break",
        "Absent" => "chip-absent",
        _ => "chip-absent"
    };

    private string GetStaffStatusDotClass(string status) => status switch
    {
        "Available" => "dot-available",
        "On Break" => "dot-break",
        "Absent" => "dot-absent",
        _ => "dot-absent"
    };

    private string GetOfficeStatusClass(string status) => status switch
    {
        "Open" => "status-open",
        "Lunch Break" => "status-lunch",
        "Closed" => "status-closed",
        _ => "status-closed"
    };

    private string GetOfficeStatusIcon(string status) => status switch
    {
        "Open" => Icons.Material.Filled.CheckCircle,
        "Lunch Break" => Icons.Material.Filled.RestaurantMenu,
        "Closed" => Icons.Material.Filled.Cancel,
        _ => Icons.Material.Filled.Cancel
    };

    private string GetCrowdStatusClass(string status) => status switch
    {
        "Open" => "crowd-open",
        "Busy" => "crowd-busy",
        "VeryBusy" => "crowd-very-busy",
        _ => "crowd-open"
    };

    private string GetCrowdStatusEmoji(string status) => status switch
    {
        "Open" => "🟢",
        "Busy" => "🟡",
        "VeryBusy" => "🔴",
        _ => "🟢"
    };

    private string GetCrowdStatusLabel(string status) => status switch
    {
        "Open" => "Come On In",
        "Busy" => "Short Wait Expected",
        "VeryBusy" => "Expect a Long Wait",
        _ => "Come On In"
    };

    private string GetTimeAgo(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} min ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} hr ago";
        return $"{(int)diff.TotalDays} day(s) ago";
    }

    // ── Navigation ────────────────────────────────────────

    private void ToggleDrawer() => drawerOpen = !drawerOpen;
    private void CloseDrawer() => drawerOpen = false;
    private void ToggleProfileMenu() => showProfileMenu = !showProfileMenu;

    private void NavigateTo(string url)
    {
        drawerOpen = false;
        Navigation.NavigateTo(url);
    }

    private void GoToProfile()
    {
        showProfileMenu = false;
        Navigation.NavigateTo("/profile");
    }

    private void HandleLogout()
    {
        showProfileMenu = false;
        Navigation.NavigateTo("/loginpage");
    }
}
