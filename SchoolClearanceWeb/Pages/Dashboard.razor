@page "/"
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="dash-page">

    <!-- BG SHAPES -->
    <div class="bg-shapes">
        <div class="bg-shape bg-s1"></div>
        <div class="bg-shape bg-s2"></div>
        <div class="bg-shape bg-s3"></div>
    </div>

    <!-- ═══ STEADY SIDEBAR (always visible, fixed) ═══ -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="aclc_logo.png" alt="ACLC Logo" class="sidebar-logo" />
            <div class="sidebar-brand-wrap">
                <span class="sidebar-brand">School Clearance</span>
                <span class="sidebar-sub">Student Portal</span>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-nav-item @(currentPage == "dashboard" ? "active" : "")"
                 @onclick='() => NavigateTo("/dashboard", "dashboard")'>
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="sidebar-nav-icon" />
                <span>Dashboard</span>
            </div>
            <div class="sidebar-section-label">OFFICES</div>
            <div class="sidebar-nav-item @(currentPage == "registrar" ? "active" : "")"
                 @onclick='() => NavigateTo("/registrar", "registrar")'>
                <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Class="sidebar-nav-icon" />
                <span>Registrar Office</span>
            </div>
            <div class="sidebar-nav-item @(currentPage == "cashier" ? "active" : "")"
                 @onclick='() => NavigateTo("/cashier", "cashier")'>
                <MudIcon Icon="@Icons.Material.Filled.Payments" Class="sidebar-nav-icon" />
                <span>Cashier Office</span>
            </div>
            <div class="sidebar-nav-item @(currentPage == "grade" ? "active" : "")"
                 @onclick='() => NavigateTo("/grade-release", "grade")'>
                <MudIcon Icon="@Icons.Material.Filled.Grade" Class="sidebar-nav-icon" />
                <span>Grade Release</span>
            </div>
            <div class="sidebar-nav-item @(currentPage == "announcements" ? "active" : "")"
                 @onclick='() => NavigateTo("/announcements", "announcements")'>
                <MudIcon Icon="@Icons.Material.Filled.Campaign" Class="sidebar-nav-icon" />
                <span>Announcements</span>
            </div>
            <div class="sidebar-section-label">ACCOUNT</div>
            <div class="sidebar-nav-item @(currentPage == "settings" ? "active" : "")"
                 @onclick='() => NavigateTo("/settings", "settings")'>
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="sidebar-nav-icon" />
                <span>Settings</span>
            </div>
        </nav>
    </div>

    <!-- ═══ TOP NAVBAR ═══ -->
    <div class="dash-navbar">

        <button class="hamburger-btn" @onclick="ToggleDrawer">
            <MudIcon Icon="@Icons.Material.Filled.Menu" Class="hamburger-icon" />
        </button>


        <div class="navbar-center">
            <div class="search-wrapper">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
                <input @bind="searchQuery"
                       @bind:event="oninput"
                       placeholder="Search staff..."
                       class="search-input" />
                @if (showSearchResults && searchResults.Any())
                {
                    <div class="search-dropdown">
                        @foreach (var staff in searchResults)
                        {
                            <div class="search-item" @onclick="() => GoToStaff(staff.StaffId)">
                                <div class="search-item-info">
                                    <span class="search-item-name">@staff.FullName</span>
                                    <span class="search-item-pos">@staff.Position — @staff.Department</span>
                                </div>
                                <span class="status-dot @GetStatusDotClass(staff.StaffStatus)"></span>
                            </div>
                        }
                    </div>
                }
                @if (showSearchResults && !searchResults.Any() && searchQuery.Length >= 2)
                {
                    <div class="search-dropdown">
                        <div class="search-empty">No staff found</div>
                    </div>
                }
            </div>
        </div>

        <!-- ═══ NAVBAR RIGHT: Notif + Avatar ═══ -->
        <div class="navbar-right">

            <!-- NOTIFICATION ICON -->
            <div class="notif-wrap">
                <div class="notif-btn" @onclick="ToggleNotifMenu">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="notif-icon" />
                    @if (unreadNotifCount > 0)
                    {
                        <span class="notif-badge">@unreadNotifCount</span>
                    }
                </div>

                @if (showNotifMenu)
                {
                    <div class="notif-dropdown">
                    </div>
                }
            </div>

            @if (showNotifMenu)
            {
                <div class="notif-dropdown">
                    <div class="notif-header">
                        <span class="notif-title">Notifications</span>
                        <span class="notif-clear" @onclick="ClearNotifs">Mark all read</span>
                    </div>
                    @if (notifications.Any())
                    {
                        @foreach (var notif in notifications)
                        {
                            <div class="notif-item @(notif.IsUnread ? "unread" : "")">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Class="notif-item-icon" />
                                <div class="notif-item-body">
                                    <span class="notif-item-text">@notif.Message</span>
                                    <span class="notif-item-time">@notif.Time</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="notif-empty">No new notifications</div>
                    }
                </div>
            }

            <!-- PROFILE AVATAR -->
            <div class="nav-avatar" @onclick="ToggleProfileMenu">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="avatar-icon" />
            </div>
            @if (showProfileMenu)
            {
                <div class="profile-dropdown">
                    <div class="profile-menu-item" @onclick="GoToProfile">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="profile-menu-icon" />
                        <span>Profile</span>
                    </div>
                    <div class="profile-menu-divider"></div>
                    <div class="profile-menu-item logout" @onclick="HandleLogout">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Class="profile-menu-icon" />
                        <span>Logout</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- MOBILE DRAWER OVERLAY -->
    @if (drawerOpen)
    {
        <div class="drawer-overlay" @onclick="CloseDrawer"></div>
    }

    <!-- MOBILE SIDE DRAWER -->
    <div class="side-drawer @(drawerOpen ? "drawer-open" : "")">
        <div class="drawer-header">
            <img src="aclc_logo.png" alt="ACLC Logo" class="drawer-logo" />
            <div class="drawer-brand-wrap">
                <span class="drawer-brand">School Clearance</span>
                <span class="drawer-sub">Student Portal</span>
            </div>
            <button class="drawer-close-btn" @onclick="CloseDrawer">
                <MudIcon Icon="@Icons.Material.Filled.Close" Class="drawer-close-icon" />
            </button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item @(currentPage == "dashboard" ? "active" : "")"
                 @onclick='() => NavigateTo("/dashboard", "dashboard")'>
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="drawer-nav-icon" />
                <span>Dashboard</span>
            </div>
            <div class="drawer-section-label">OFFICES</div>
            <div class="drawer-nav-item @(currentPage == "registrar" ? "active" : "")"
                 @onclick='() => NavigateTo("/registrar", "registrar")'>
                <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Class="drawer-nav-icon" />
                <span>Registrar Office</span>
            </div>
            <div class="drawer-nav-item @(currentPage == "cashier" ? "active" : "")"
                 @onclick='() => NavigateTo("/cashier", "cashier")'>
                <MudIcon Icon="@Icons.Material.Filled.Payments" Class="drawer-nav-icon" />
                <span>Cashier Office</span>
            </div>
            <div class="drawer-nav-item @(currentPage == "grade" ? "active" : "")"
                 @onclick='() => NavigateTo("/grade-release", "grade")'>
                <MudIcon Icon="@Icons.Material.Filled.Grade" Class="drawer-nav-icon" />
                <span>Grade Release</span>
            </div>
            <div class="drawer-nav-item @(currentPage == "announcements" ? "active" : "")"
                 @onclick='() => NavigateTo("/announcements", "announcements")'>
                <MudIcon Icon="@Icons.Material.Filled.Campaign" Class="drawer-nav-icon" />
                <span>Announcements</span>
            </div>
            <div class="drawer-section-label">ACCOUNT</div>
            <div class="drawer-nav-item @(currentPage == "settings" ? "active" : "")"
                 @onclick='() => NavigateTo("/settings", "settings")'>
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="drawer-nav-icon" />
                <span>Settings</span>
            </div>
        </nav>
    </div>

    <!-- PAGE CONTENT -->
    <div class="dash-content">

        <!-- GREETING -->
        <div class="greeting-card">
            <div class="greeting-left">
                <div class="greeting-time-row">
                    <MudIcon Icon="@GetGreetingIcon()" Class="greeting-time-icon" />
                    <span class="greeting-time">@GetGreetingTime()</span>
                </div>
                <span class="greeting-name">Hello, @(dashboardData?.FullName ?? "Student")!</span>
                <span class="greeting-sub">Here's your clearance status today.</span>
            </div>
            <div class="greeting-badge">
                <span class="greeting-pct">@ClearancePercent%</span>
                <span class="greeting-pct-label">Cleared</span>
            </div>
        </div>

        <!-- OFFICE QUICK ACCESS -->
        <div class="glass-card">
            <div class="section-header">
                <MudIcon Icon="@Icons.Material.Filled.Business" Class="section-icon" />
                <MudText Typo="Typo.h6" Class="section-title">Office Quick Access</MudText>
            </div>
            <div class="office-grid">

                <div class="office-card" @onclick='() => Navigation.NavigateTo("/registrar")'>
                    <div class="office-icon-wrap" style="background: rgba(96,165,250,0.2);">
                        <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Class="office-icon" />
                    </div>
                    <div class="office-info">
                        <span class="office-name">Registrar</span>
                        <span class="office-status-badge badge-open">Open</span>
                        <span class="office-schedule">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Class="schedule-icon" />
                            8:00 AM – 5:00 PM
                        </span>
                        <span class="office-hours-detail">
                            Opens: 8:00 AM &nbsp;|&nbsp; Closes: 5:00 PM
                        </span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="office-arrow" />
                </div>

                <div class="office-card" @onclick='() => Navigation.NavigateTo("/cashier")'>
                    <div class="office-icon-wrap" style="background: rgba(234,179,8,0.2);">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Class="office-icon" />
                    </div>
                    <div class="office-info">
                        <span class="office-name">Cashier</span>
                        <span class="office-status-badge badge-lunch">Lunch Break</span>
                        <span class="office-schedule">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Class="schedule-icon" />
                            8:00 AM – 5:00 PM
                        </span>
                        <span class="office-hours-detail">
                            Opens: 8:00 AM &nbsp;|&nbsp; Closes: 5:00 PM
                        </span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="office-arrow" />
                </div>

                <div class="office-card" @onclick='() => Navigation.NavigateTo("/grade-release")'>
                    <div class="office-icon-wrap" style="background: rgba(34,197,94,0.2);">
                        <MudIcon Icon="@Icons.Material.Filled.Grade" Class="office-icon" />
                    </div>
                    <div class="office-info">
                        <span class="office-name">Grade Release</span>
                        <span class="office-status-badge badge-open">Open</span>
                        <span class="office-schedule">
                            <MudIcon Icon="@Icons.Material.Filled.AccessTime" Class="schedule-icon" />
                            8:00 AM – 5:00 PM
                        </span>
                        <span class="office-hours-detail">
                            Opens: 8:00 AM &nbsp;|&nbsp; Closes: 5:00 PM
                        </span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Class="office-arrow" />
                </div>

            </div>
        </div>

        <!-- PROGRESS + CHECKLIST SIDE BY SIDE -->
        <div class="progress-checklist-row">

            <!-- PROGRESS CARD -->
            <div class="glass-card progress-graphic-card">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Class="section-icon" />
                    <MudText Typo="Typo.h6" Class="section-title">Progress</MudText>
                </div>
                <div class="progress-circle-wrap">
                    <div class="progress-circle">
                        <svg class="circle-svg" viewBox="0 0 120 120">
                            <circle class="circle-bg" cx="60" cy="60" r="50" fill="none" />
                            <circle class="circle-fill" cx="60" cy="60" r="50"
                                    fill="none"
                                    stroke-dasharray="@($"{ClearancePercent * 3.1416:F1} 314.16")"
                                    stroke-dashoffset="0"
                                    transform="rotate(-90 60 60)" />
                        </svg>
                        <div class="circle-label">
                            <span class="circle-pct">@ClearancePercent%</span>
                            <span class="circle-sub">Cleared</span>
                        </div>
                    </div>
                </div>
                <div class="progress-stats-row">
                    <div class="progress-stat-chip cleared-chip">
                        <span class="stat-num">@clearedCount</span>
                        <span class="stat-lbl">Done</span>
                    </div>
                    <div class="progress-stat-chip pending-chip">
                        <span class="stat-num">@(clearanceItems.Count - clearedCount)</span>
                        <span class="stat-lbl">Pending</span>
                    </div>
                    <div class="progress-stat-chip total-chip">
                        <span class="stat-num">@clearanceItems.Count</span>
                        <span class="stat-lbl">Total</span>
                    </div>
                </div>
            </div>

            <!-- CHECKLIST CARD -->
            <div class="glass-card checklist-card">
                <div class="section-header">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="section-icon" />
                    <MudText Typo="Typo.h6" Class="section-title">My Clearance Checklist</MudText>
                </div>
                <div class="checklist">
                    @if (clearanceItems.Count == 0)
                    {
                        <div class="checklist-empty">No clearance items found.</div>
                    }
                    else
                    {
                        @foreach (var item in clearanceItems)
                        {
                            <div class="checklist-item @(item.IsCleared ? "cleared" : "")">
                                <MudCheckBox @bind-Value="item.IsCleared" Color="Color.Success" />
                                <div class="checklist-info">
                                    <span class="checklist-name">@item.Name</span>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <span class="checklist-desc">@item.Description</span>
                                    }
                                </div>
                                @if (item.IsCleared && item.ClearedAt.HasValue)
                                {
                                    <span class="checklist-date">@item.ClearedAt.Value.ToString("MMM dd")</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

        </div>

    </div>
</div>

@code {
    private string searchQuery = "";
    private bool showSearchResults = false;
    private bool drawerOpen = false;
    private bool showProfileMenu = false;
    private bool showNotifMenu = false;
    private string currentPage = "dashboard";
    private List<StaffListModel> searchResults = new();

    private StudentDashboardResponse? dashboardData;
    private List<ClearanceItemModel> clearanceItems = new();

    private List<NotificationModel> notifications = new();

    private int unreadNotifCount => notifications.Count(n => n.IsUnread);

    private int clearedCount => clearanceItems.Count(x => x.IsCleared);
    private int ClearancePercent => clearanceItems.Count == 0 ? 0
        : (int)Math.Round((double)clearedCount / clearanceItems.Count * 100);

    // Circle SVG dash calculation: circumference = 2 * π * r = 2 * 3.14159 * 50 ≈ 314.16
    private string CircleDash => $"{ClearancePercent * 3.1416:F1} 314.16";

    [Inject] private StudentService StudentService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");
        var studentIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "studentId");
        int.TryParse(studentIdStr, out int studentId);

        var result = await StudentService.GetDashboard(studentId, token);
        if (result?.Status == 1 && result.Data != null)
        {
            dashboardData = result.Data;
            clearanceItems = dashboardData.ClearanceItems ?? new();
        }
    }

    private void ToggleDrawer() => drawerOpen = !drawerOpen;
    private void CloseDrawer() => drawerOpen = false;
    private void ToggleProfileMenu()
    {
        showProfileMenu = !showProfileMenu;
        if (showProfileMenu) showNotifMenu = false;
    }
    private void ToggleNotifMenu()
    {
        showNotifMenu = !showNotifMenu;
        if (showNotifMenu) showProfileMenu = false;
    }
    private void ClearNotifs()
    {
        foreach (var n in notifications) n.IsUnread = false;
    }

    private void NavigateTo(string url, string page)
    {
        currentPage = page;
        drawerOpen = false;
        Navigation.NavigateTo(url);
    }

    private void GoToProfile()
    {
        showProfileMenu = false;
        Navigation.NavigateTo("/profile");
    }

    private void HandleLogout()
    {
        showProfileMenu = false;
        Navigation.NavigateTo("/loginpage");
    }

    private void GoToStaff(int staffId)
    {
        showSearchResults = false;
        searchQuery = "";
        Navigation.NavigateTo($"/staff/{staffId}");
    }

    private string GetGreetingTime()
    {
        var hour = DateTime.Now.Hour;
        return hour < 12 ? "Good Morning" : hour < 17 ? "Good Afternoon" : "Good Evening";
    }

    private string GetGreetingIcon()
    {
        var hour = DateTime.Now.Hour;
        return hour < 12 ? Icons.Material.Filled.WbSunny
             : hour < 17 ? Icons.Material.Filled.WbCloudy
             : Icons.Material.Filled.Bedtime;
    }

    private string GetStatusDotClass(string status) => status switch
    {
        "Available" => "dot-green",
        "On Break" => "dot-yellow",
        "Absent" => "dot-red",
        _ => "dot-grey"
    };

    // Simple notification model — move to a shared models file if preferred
    private class NotificationModel
    {
        public string Message { get; set; } = "";
        public string Time { get; set; } = "";
        public bool IsUnread { get; set; }
    }
}