@page "/register"
@inject UserService UserService
@inject NavigationManager Navigation

<div class="auth-bg">
    <div class="floating-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
        <div class="shape shape-4"></div>
    </div>
    <div class="auth-card">
        <!-- Left Panel -->
        <div class="auth-left">
            <div class="logo-ring">
                <img src="aclc_logo.png" alt="ACLC Logo" class="logo-img" />
            </div>
            <MudText Typo="Typo.h5" Class="app-title">School Clearance</MudText>
            <MudText Typo="Typo.caption" Class="app-subtitle">Create Your Account</MudText>
            <div class="divider"></div>
            <MudText Typo="Typo.body2" Class="app-desc">
                Join the school clearance system and manage your requests with ease.
            </MudText>
        </div>

        <!-- Right Panel -->
        <div class="auth-right">
            <MudText Typo="Typo.h4" Class="form-title">Register</MudText>
            <MudText Typo="Typo.body2" Class="form-desc">Fill in your details to get started</MudText>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">
                    @errorMessage
                </MudAlert>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">
                    @successMessage
                </MudAlert>
            }

            <div class="field-gap">
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudTextField @bind-Value="firstName"
                                      Placeholder="First Name"
                                      Variant="Variant.Outlined"
                                      FullWidth="true" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="lastName"
                                      Placeholder="Last Name"
                                      Variant="Variant.Outlined"
                                      FullWidth="true" />
                    </MudItem>
                </MudGrid>
            </div>

            <div class="field-gap">
                <MudTextField @bind-Value="username"
                              Placeholder="Username"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              FullWidth="true" />
            </div>

            <div class="field-gap">
                <div class="custom-input-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="custom-icon-left" />
                    <MudTextField @bind-Value="password"
                                  Placeholder="Password"
                                  Variant="Variant.Outlined"
                                  InputType="@passwordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@passwordIcon"
                                  OnAdornmentClick="TogglePassword"
                                  FullWidth="true"
                                  Class="custom-padded" />
                </div>
            </div>

            <div class="field-gap">
                <div class="custom-input-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="custom-icon-left" />
                    <MudTextField @bind-Value="confirmPassword"
                                  Placeholder="Confirm Password"
                                  Variant="Variant.Outlined"
                                  InputType="@confirmPasswordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@confirmPasswordIcon"
                                  OnAdornmentClick="ToggleConfirmPassword"
                                  Error="@PasswordMismatch"
                                  ErrorText="Passwords do not match"
                                  FullWidth="true"
                                  Class="custom-padded" />
                </div>
            </div>

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Size="Size.Large"
                       Class="auth-btn"
                       OnClick="HandleRegister"
                       Disabled="@isLoading">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Creating account...</span>
                }
                else
                {
                    <span>Create Account</span>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="ml-2" />
                }
            </MudButton>

            <MudText Align="Align.Center" Typo="Typo.body2" Class="mt-4 switch-link">
                Already have an account?
                <MudLink Href="/" Class="auth-link">Sign in here</MudLink>
            </MudText>
        </div>
    </div>
</div>

@code {
  

    private string firstName = "";
    private string lastName = "";
    private string username = "";
    private string password = "";
    private string confirmPassword = "";
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";

    private bool PasswordMismatch =>
        !string.IsNullOrEmpty(confirmPassword) && password != confirmPassword;

    private InputType passwordInput => showPassword ? InputType.Text : InputType.Password;
    private string passwordIcon => showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private InputType confirmPasswordInput => showConfirmPassword ? InputType.Text : InputType.Password;
    private string confirmPasswordIcon => showConfirmPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private void TogglePassword() => showPassword = !showPassword;
    private void ToggleConfirmPassword() => showConfirmPassword = !showConfirmPassword;

    private async Task HandleRegister()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName) ||
            string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "All fields are required.";
            return;
        }
        if (username.Length < 4) { errorMessage = "Username must be at least 4 characters."; return; }
        if (password.Length < 8) { errorMessage = "Password must be at least 8 characters."; return; }
        if (PasswordMismatch) { errorMessage = "Passwords do not match."; return; }

        isLoading = true;
        await Task.Delay(500);
        isLoading = false;

        bool registered = UserService.Register(firstName, lastName, username, password);
        if (registered)
        {
            successMessage = "Account created successfully! You can now sign in.";
            await Task.Delay(1500);
            Navigation.NavigateTo("/"); // redirect to login
        }
        else
        {
            errorMessage = "Username already taken. Please choose another.";
        }
    }
}
