@page "/register"
@inject NavigationManager Navigation
@inject AuthService AuthService

<div class="auth-bg">
    <div class="floating-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
        <div class="shape shape-4"></div>
    </div>
    <div class="auth-card register-card">
        <!-- Left Panel -->
        <div class="auth-left">
            <div class="logo-ring">
                <img src="aclc_logo.png" alt="ACLC Logo" class="logo-img" />
            </div>
            <MudText Typo="Typo.h5" Class="app-title">School Clearance</MudText>
            <MudText Typo="Typo.caption" Class="app-subtitle">Create Your Account</MudText>
            <div class="divider"></div>
            <MudText Typo="Typo.body2" Class="app-desc">
                Join the school clearance system and manage your requests with ease.
            </MudText>
        </div>

        <!-- Right Panel -->
        <div class="auth-right">
            <MudText Typo="Typo.h4" Class="form-title">Register</MudText>
            <MudText Typo="Typo.body2" Class="form-desc">Fill in your details to get started</MudText>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">@errorMessage</MudAlert>
            }
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <MudAlert Severity="Severity.Success" Class="mb-3" Dense="true">@successMessage</MudAlert>
            }

            <div class="field-gap">
                <MudTextField @bind-Value="fullName"
                              Placeholder="Full Name"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              FullWidth="true" />
            </div>

            <div class="field-gap">
                <MudTextField @bind-Value="studentNo"
                              Placeholder="Student No. (e.g. 2024-00123)"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Badge"
                              FullWidth="true" />
            </div>

            <div class="field-gap">
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="6">
                        <MudSelect Value="@department"
                                   ValueChanged="@((string val) => OnDepartmentChanged(val))"
                                   Label="Department"
                                   Variant="Variant.Outlined"
                                   FullWidth="true"
                                   T="string">
                            <MudSelectItem Value="@("College")">College</MudSelectItem>
                            <MudSelectItem Value="@("Senior High School")">Senior High School</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudSelect @bind-Value="courseStrand"
                                   Label="Course / Strand"
                                   Variant="Variant.Outlined"
                                   FullWidth="true"
                                   Disabled="@(string.IsNullOrEmpty(department))"
                                   T="string">
                            @foreach (var c in courseOptions)
                            {
                                <MudSelectItem Value="@c">@c</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </div>

            <div class="field-gap">
                <MudSelect @bind-Value="yearLevel"
                           Label="Year Level"
                           Variant="Variant.Outlined"
                           FullWidth="true"
                           Disabled="@(string.IsNullOrEmpty(department))"
                           T="string">
                    @foreach (var y in yearOptions)
                    {
                        <MudSelectItem Value="@y">@y</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <div class="field-gap">
                <MudTextField @bind-Value="username"
                              Placeholder="Username"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                              FullWidth="true" />
            </div>

            <div class="field-gap">
                <div class="custom-input-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="custom-icon-left" />
                    <MudTextField @bind-Value="password"
                                  Placeholder="Password"
                                  Variant="Variant.Outlined"
                                  InputType="@passwordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@passwordIcon"
                                  OnAdornmentClick="TogglePassword"
                                  FullWidth="true"
                                  Class="custom-padded" />
                </div>
            </div>

            <div class="field-gap">
                <div class="custom-input-wrapper">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="custom-icon-left" />
                    <MudTextField @bind-Value="confirmPassword"
                                  Placeholder="Confirm Password"
                                  Variant="Variant.Outlined"
                                  InputType="@confirmPasswordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@confirmPasswordIcon"
                                  OnAdornmentClick="ToggleConfirmPassword"
                                  Error="@PasswordMismatch"
                                  ErrorText="Passwords do not match"
                                  FullWidth="true"
                                  Class="custom-padded" />
                </div>
            </div>

            <MudButton Variant="Variant.Filled"
                       FullWidth="true"
                       Size="Size.Large"
                       Class="auth-btn"
                       OnClick="HandleRegister"
                       Disabled="@isLoading">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Creating account...</span>
                }
                else
                {
                    <span>Create Account</span>
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="ml-2" />
                }
            </MudButton>

            <MudText Align="Align.Center" Typo="Typo.body2" Class="mt-4 switch-link">
                Already have an account?
                <MudLink Href="/" Class="auth-link">Sign in here</MudLink>
            </MudText>
        </div>
    </div>
</div>

@code {
    private string fullName = "";
    private string studentNo = "";
    private string department = "";
    private string courseStrand = "";
    private string yearLevel = "";
    private string username = "";
    private string password = "";
    private string confirmPassword = "";
    private bool showPassword = false;
    private bool showConfirmPassword = false;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";

    private List<string> courseOptions = new();
    private List<string> yearOptions = new();

    private static readonly List<string> CollegeCourses = new()
    {
        "BS Information Technology",
        "BS Computer Science",
        "BS Business Administration",
        "BS Accountancy",
        "BS Hospitality Management",
        "BS Tourism Management"
    };

    private static readonly List<string> SHSStrands = new()
    {
        "ABM — Accountancy, Business & Management",
        "HUMSS — Humanities & Social Sciences",
        "STEM — Science, Technology, Engineering & Math",
        "TVL — Technical-Vocational-Livelihood",
        "GAS — General Academic Strand"
    };

    private static readonly List<string> CollegeYears = new()
    {
        "1st Year", "2nd Year", "3rd Year", "4th Year"
    };

    private static readonly List<string> SHSYears = new()
    {
        "Grade 11", "Grade 12"
    };

    private void OnDepartmentChanged(string val)
    {
        department = val;
        courseStrand = "";
        yearLevel = "";

        if (department == "College")
        {
            courseOptions = CollegeCourses;
            yearOptions = CollegeYears;
        }
        else if (department == "Senior High School")
        {
            courseOptions = SHSStrands;
            yearOptions = SHSYears;
        }
        else
        {
            courseOptions = new();
            yearOptions = new();
        }
    }
    @code {
    private bool PasswordMismatch =>
        !string.IsNullOrEmpty(confirmPassword) && password != confirmPassword;          

    private InputType passwordInput => showPassword ? InputType.Text : InputType.Password;
    private string passwordIcon => showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private InputType confirmPasswordInput => showConfirmPassword ? InputType.Text : InputType.Password;
    private string confirmPasswordIcon => showConfirmPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private void TogglePassword() => showPassword = !showPassword;
    private void ToggleConfirmPassword() => showConfirmPassword = !showConfirmPassword;


    private async Task HandleRegister()
{
    errorMessage = "";
    successMessage = "";

    if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(studentNo) ||
        string.IsNullOrWhiteSpace(department) || string.IsNullOrWhiteSpace(courseStrand) ||
        string.IsNullOrWhiteSpace(yearLevel) || string.IsNullOrWhiteSpace(username) ||
        string.IsNullOrWhiteSpace(password))
    {
        errorMessage = "All fields are required.";
        return;
    }

    if (username.Length < 4) { errorMessage = "Username must be at least 4 characters."; return; }
    if (password.Length < 8) { errorMessage = "Password must be at least 8 characters."; return; }
    if (PasswordMismatch) { errorMessage = "Passwords do not match."; return; }

    isLoading = true;

    var result = await AuthService.RegisterStudent(new StudentRegisterRequest
    {
        StudentNo = studentNo,
        Username = username,
        Password = password,
        FullName = fullName,
        Department = department,
        CourseStrand = courseStrand,
        YearLevel = yearLevel
    });

    isLoading = false;

    if (result.Status == 1)
    {
        successMessage = "Account created! Redirecting to login...";
        await Task.Delay(1500);
        Navigation.NavigateTo("/");
    }
    else
    {
        errorMessage = result.Message;
    }
}

        }
    }
        