@page "/admin/coupons"
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using MudBlazor

<PageTitle>Coupon Management</PageTitle>

<div class="page-bg">
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>

    @if (drawerOpen)
    {
        <div class="drawer-overlay" @onclick="CloseDrawer"></div>
    }

    <div class="side-drawer @(drawerOpen ? "drawer-open" : "")">
        <div class="drawer-header">
            <img src="aclc_logo.png" alt="ACLC" class="drawer-logo" />
            <div class="drawer-brand-wrap">
                <span class="drawer-brand">School Clearance</span>
                <span class="drawer-sub">Admin Panel</span>
            </div>
            <button class="drawer-close-btn" @onclick="CloseDrawer">
                <MudIcon Icon="@Icons.Material.Filled.Close" style="color:white; font-size:18px;" />
            </button>
        </div>
        <nav style="padding: 12px 8px;">
            <p class="nav-section">Main</p>
            <div class="nav-item" @onclick='() => NavigateTo("/admin/dashboard")'>
                <MudIcon Icon="@Icons.Material.Filled.GridView" Class="nav-icon" />
                <span>Dashboard</span>
            </div>
            <p class="nav-section">Management</p>
            <div class="nav-item nav-active" @onclick='() => NavigateTo("/admin/coupons")'>
                <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Class="nav-icon" />
                <span>Coupons</span>
            </div>
            <div class="nav-item" @onclick='() => NavigateTo("/admin/staff")'>
                <MudIcon Icon="@Icons.Material.Filled.People" Class="nav-icon" />
                <span>Staff</span>
            </div>
            <div style="margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.08); padding-top:12px;">
                <div class="nav-item logout-item" @onclick="HandleLogout">
                    <MudIcon Icon="@Icons.Material.Filled.Logout" Class="nav-icon" />
                    <span>Logout</span>
                </div>
            </div>
        </nav>
    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <img src="aclc_logo.png" alt="ACLC" class="logo-img" />
            <div class="brand-text">
                <span class="brand-name">School Clearance</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </div>

        <p class="nav-section">Main</p>
        <div class="nav-item" @onclick='() => Navigation.NavigateTo("/admin/dashboard")'>
            <MudIcon Icon="@Icons.Material.Filled.GridView" Class="nav-icon" />
            <span>Dashboard</span>
        </div>

        <p class="nav-section">Management</p>
        <div class="nav-item nav-active" @onclick='() => Navigation.NavigateTo("/admin/coupons")'>
            <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Class="nav-icon" />
            <span>Coupons</span>
        </div>
        <div class="nav-item" @onclick='() => Navigation.NavigateTo("/admin/staff")'>
            <MudIcon Icon="@Icons.Material.Filled.People" Class="nav-icon" />
            <span>Staff</span>
        </div>

        <div class="sidebar-footer">
            <div class="nav-item logout-item" @onclick="HandleLogout">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="nav-icon" />
                <span>Logout</span>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- TOPBAR -->
        <div class="topbar">
            <div style="display:flex; align-items:center; gap:12px;">
                <button class="hamburger-btn" @onclick="ToggleDrawer">
                    <MudIcon Icon="@Icons.Material.Filled.Menu" style="color:white;" />
                </button>
            <MudText Typo="Typo.h5" Class="page-title">Coupon Management</MudText>
        </div>
            <div class="avatar-circle">A</div>
        </div>

        <!-- TWO COLUMN LAYOUT -->
        <div class="coupon-layout">

            <!-- LEFT: GENERATE FORM -->
            <div class="generate-col">
                <div class="glass-card section-card">
                    <div class="section-card-header">
                        <div class="section-icon-wrap">
                            <MudIcon Icon="@Icons.Material.Filled.AddCard"
                                     Style="color: white; font-size: 1.3rem;" />
                        </div>
                        <div>
                            <p class="section-card-title">Generate Coupon</p>
                            <p class="section-card-sub">Create a one-time registration code</p>
                        </div>
                    </div>

                    <div class="form-fields">
                        <div class="field-group">
                            <label class="field-label">Full Name</label>
                            <input class="glass-input" type="text" placeholder="e.g. Juan Dela Cruz"
                                   @bind="fullName" />
                        </div>

                        <div class="field-group">
                            <label class="field-label">Position</label>
                            <div class="glass-select-wrap">
                                <select class="glass-select" @bind="position">
                                    <option value="" disabled selected>Select position</option>
                                    <option value="Teacher">Teacher</option>
                                    <option value="Registrar">Registrar</option>
                                    <option value="Cashier">Cashier</option>
                                    <option value="Grade Release">Grade Release</option>
                                </select>
                            </div>
                        </div>

                        <div class="field-group">
                            <label class="field-label">Department</label>
                            <div class="glass-select-wrap">
                                <select class="glass-select" @bind="department">
                                    <option value="" disabled selected>Select department</option>
                                    <option value="College">College</option>
                                    <option value="Senior High School">Senior High School</option>
                                </select>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert-error">@errorMessage</div>
                        }
                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert-success">@successMessage</div>
                        }

                        <button class="generate-btn" @onclick="HandleGenerate" disabled="@isGenerating">
                            @if (isGenerating)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" />
                                <span>Generating...</span>
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome"
                                         Style="font-size: 1rem;" />
                                <span>Generate Coupon</span>
                            }
                        </button>
                    </div>
                </div>
            </div>

            <!-- RIGHT: COUPONS TABLE -->
            <div class="table-col">
                <div class="glass-card section-card">
                    <div class="section-card-header">
                        <div class="section-icon-wrap" style="background: rgba(234,179,8,0.25);">
                            <MudIcon Icon="@Icons.Material.Filled.ListAlt"
                                     Style="color: #EAB308; font-size: 1.3rem;" />
                        </div>
                        <div>
                            <p class="section-card-title">All Coupons</p>
                            <p class="section-card-sub">Browse usage and status</p>
                        </div>
                        <button class="refresh-btn" @onclick="LoadCoupons">
                            <MudIcon Icon="@Icons.Material.Filled.Refresh"
                                     Style="font-size: 1.1rem;" />
                        </button>
                    </div>

                    <div class="table-wrapper">
                        <div class="custom-table">
                            <div class="table-head coupon-head">
                                <span>Code</span>
                                <span>Full Name</span>
                                <span>Position</span>
                                <span>Department</span>
                                <span>Status</span>
                                <span>Used By</span>
                                <span>Used At</span>
                            </div>
                            @if (isLoadingCoupons)
                            {
                                <div class="empty-state">
                                    <MudProgressCircular Indeterminate="true" Size="Size.Medium" />
                                </div>
                            }
                            else if (coupons.Count == 0)
                            {
                                <div class="empty-state">
                                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Class="empty-icon" />
                                    <span class="empty-text">No coupons yet. Generate one to get started.</span>
                                </div>
                            }
                            else
                            {
                                @foreach (var c in coupons)
                                {
                                    <div class="table-row coupon-row">
                                        <span class="row-code">@c.Code</span>
                                        <span class="row-name">@c.FullName</span>
                                        <span class="row-cell">@c.Position</span>
                                        <span class="row-cell">@c.Department</span>
                                        <span class="status-chip @(c.IsUsed ? "chip-absent" : "chip-available")">
                                            @(c.IsUsed ? "Used" : "Available")
                                        </span>
                                        <span class="row-cell">@(c.UsedByUsername ?? "—")</span>
                                        <span class="row-cell">@(c.UsedAt.HasValue ? c.UsedAt.Value.ToString("MMM dd, yyyy") : "—")</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- GENERATED COUPON DIALOG -->
@if (showDialog)
{
    <div class="dialog-overlay" @onclick="CloseDialog"></div>
    <div class="dialog-box" @onclick:stopPropagation="true">
        <div class="dialog-header">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                     Style="color: #22c55e; font-size: 1.4rem;" />
            <span class="dialog-title">Coupon Generated!</span>
        </div>
        <p class="dialog-hint">Share this code with the staff member:</p>
        <div class="dialog-code">@generatedCode</div>
        <div class="dialog-actions">
            <button class="dialog-cancel" @onclick="CopyCode">Copy Code</button>
            <button class="dialog-confirm confirm-assign" @onclick="CloseDialog">Close</button>
        </div>
    </div>
}

@code {
    private string fullName = "";
    private string position = "";
    private string department = "";
    private string token = "";
    private string errorMessage = "";
    private string successMessage = "";
    private string generatedCode = "";
    private bool isGenerating = false;
    private bool isLoadingCoupons = false;
    private bool showDialog = false;
    private bool drawerOpen = false;
    private void ToggleDrawer() => drawerOpen = !drawerOpen;
    private void CloseDrawer() => drawerOpen = false;
    private void NavigateTo(string url)
    {
        drawerOpen = false;
        Navigation.NavigateTo(url);
    }

    private List<GetAllCouponsResponse> coupons = new();

    [Inject] AdminService AdminService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        token = await JS.InvokeAsync<string>("localStorage.getItem", "token");
        await LoadCoupons();
    }

    private async Task LoadCoupons()
    {
        isLoadingCoupons = true;
        var result = await AdminService.GetAllCoupons(token);
        if (result?.Status == 1 && result.Data != null)
            coupons = result.Data;
        else
            coupons = new();
        isLoadingCoupons = false;
    }

    private async Task HandleGenerate()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(fullName) ||
            string.IsNullOrWhiteSpace(position) ||
            string.IsNullOrWhiteSpace(department))
        {
            errorMessage = "All fields are required.";
            return;
        }

        isGenerating = true;

        var result = await AdminService.GenerateCoupon(new GenerateCouponRequest
            {
                FullName = fullName,
                Position = position,
                Department = department
            }, token);

        isGenerating = false;

        if (result?.Status == 1 && result.Data != null)
        {
            generatedCode = result.Data.Code;
            showDialog = true;
            fullName = "";
            position = "";
            department = "";
            await LoadCoupons();
        }
        else
        {
            errorMessage = result?.Message ?? "Failed to generate coupon.";
        }
    }

    private async Task CopyCode()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", generatedCode);
        successMessage = "Code copied!";
    }

    private void CloseDialog() => showDialog = false;
    private void HandleLogout() => Navigation.NavigateTo("/");
}