@page "/admin/dashboard"
@inject NavigationManager Navigation
@using MudBlazor
@inject IJSRuntime JS

<PageTitle>Admin Dashboard</PageTitle>

<div class="page-bg">
    <div class="orb orb1"></div>
    <div class="orb orb2"></div>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-logo">
            <img src="aclc_logo.png" alt="ACLC" class="logo-img" />
            <div class="brand-text">
                <span class="brand-name">School Clearance</span>
                <span class="brand-sub">Admin Panel</span>
            </div>
        </div>

        <p class="nav-section">Main</p>
        <div class="nav-item nav-active" @onclick='() => Navigation.NavigateTo("/admin/dashboard")'>
            <MudIcon Icon="@Icons.Material.Filled.GridView" Class="nav-icon" />
            <span>Dashboard</span>
        </div>

        <p class="nav-section">Management</p>
        <div class="nav-item" @onclick='() => Navigation.NavigateTo("/admin/coupons")'>
            <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Class="nav-icon" />
            <span>Coupons</span>
        </div>
        <div class="nav-item" @onclick='() => Navigation.NavigateTo("/admin/staff")'>
            <MudIcon Icon="@Icons.Material.Filled.People" Class="nav-icon" />
            <span>Staff</span>
        </div>

        <div class="sidebar-footer">
            <div class="nav-item logout-item" @onclick="HandleLogout">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="nav-icon" />
                <span>Logout</span>
            </div>
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- TOPBAR -->
        <div class="topbar">
            <MudText Typo="Typo.h5" Class="page-title">Dashboard</MudText>
            <div class="avatar-circle">A</div>
        </div>

        <!-- GREETING CARD -->
        <div class="glass-card greeting-card">
            <div class="greeting-left">
                <div class="greeting-time-row">
                    <MudIcon Icon="@GetGreetingIcon()" Class="greeting-time-icon" />
                    <span class="greeting-time">@GetGreetingTime()</span>
                </div>
                <span class="greeting-name">Welcome back, Admin!</span>
                <span class="greeting-sub">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</span>
            </div>
            <div class="admin-badge">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Class="admin-badge-icon" />
                <span class="admin-badge-label">IT HEAD</span>
            </div>
        </div>

        <!-- STATS -->
        <p class="section-label">Overview</p>
        <div class="stats-grid">
            <div class="stat-card glass-card">
                <div class="stat-icon-wrap stat-blue">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Class="stat-icon" />
                </div>
                <span class="stat-number">@totalCoupons</span>
                <span class="stat-label">Total Coupons</span>
            </div>
            <div class="stat-card glass-card">
                <div class="stat-icon-wrap stat-green">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="stat-icon" />
                </div>
                <span class="stat-number">@usedCoupons</span>
                <span class="stat-label">Used Coupons</span>
            </div>
            <div class="stat-card glass-card">
                <div class="stat-icon-wrap stat-purple">
                    <MudIcon Icon="@Icons.Material.Filled.People" Class="stat-icon" />
                </div>
                <span class="stat-number">@totalStaff</span>
                <span class="stat-label">Total Staff</span>
            </div>
            <div class="stat-card glass-card">
                <div class="stat-icon-wrap stat-yellow">
                    <MudIcon Icon="@Icons.Material.Filled.School" Class="stat-icon" />
                </div>
                <span class="stat-number">@totalTeachers</span>
                <span class="stat-label">Total Teachers</span>
            </div>
        </div>

        <!-- QUICK ACTIONS -->
        <p class="section-label">Quick Actions</p>
        <div class="actions-grid">
            <div class="action-card glass-card" @onclick='() => Navigation.NavigateTo("/admin/coupons")'>
                <div class="action-icon-wrap qa-blue">
                    <MudIcon Icon="@Icons.Material.Filled.AddCard" Class="action-icon" />
                </div>
                <span class="action-title">Generate Coupon</span>
                <span class="action-sub">Create a one-time registration code</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="action-arrow" />
            </div>
            <div class="action-card glass-card" @onclick='() => Navigation.NavigateTo("/admin/coupons")'>
                <div class="action-icon-wrap qa-yellow">
                    <MudIcon Icon="@Icons.Material.Filled.ListAlt" Class="action-icon" />
                </div>
                <span class="action-title">View All Coupons</span>
                <span class="action-sub">Browse coupon usage and status</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="action-arrow" />
            </div>
            <div class="action-card glass-card" @onclick='() => Navigation.NavigateTo("/admin/staff")'>
                <div class="action-icon-wrap qa-green">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="action-icon" />
                </div>
                <span class="action-title">Manage Staff</span>
                <span class="action-sub">Assign or revoke teacher roles</span>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Class="action-arrow" />
            </div>
        </div>

    </div>
</div>

  @code {
    private int totalCoupons = 0;
    private int usedCoupons = 0;
    private int totalStaff = 0;
    private int totalTeachers = 0;

    private string token = "";

    [Inject] AdminService AdminService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        var couponsResult = await AdminService.GetAllCoupons(token);
        if (couponsResult?.Status == 1 && couponsResult.Data != null)
        {
            totalCoupons = couponsResult.Data.Count;
            usedCoupons = couponsResult.Data.Count(c => c.IsUsed);
        }

        var staffResult = await AdminService.GetAllStaff(token);
        if (staffResult?.Status == 1 && staffResult.Data != null)
            totalStaff = staffResult.Data.Count;

        var teachersResult = await AdminService.GetAllTeachers(token);
        if (teachersResult?.Status == 1 && teachersResult.Data != null)
            totalTeachers = teachersResult.Data.Count;
    }

    private string GetGreetingTime()
    {
        var h = DateTime.Now.Hour;
        return h < 12 ? "Good Morning" : h < 17 ? "Good Afternoon" : "Good Evening";
    }

    private string GetGreetingIcon()
    {
        var h = DateTime.Now.Hour;
        return h < 12 ? Icons.Material.Filled.WbSunny
             : h < 17 ? Icons.Material.Filled.WbCloudy
             : Icons.Material.Filled.Bedtime;
    }

    private void HandleLogout() => Navigation.NavigateTo("/");
}