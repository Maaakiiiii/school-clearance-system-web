@page "/"
@using MudBlazor

<PageTitle>Admin Dashboard</PageTitle>

<div class="admin-root">

    <!-- DECORATIVE BLOBS -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <img src="images/aclc-logo.png" alt="ACLC" class="logo-img" />
            <span class="logo-text">Admin</span>
        </div>

        <nav class="sidebar-nav">
            <a class="nav-item active" href="/admin/dashboard">
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="nav-icon" />
                <span>Dashboard</span>
            </a>
            <a class="nav-item" href="/admin/coupons">
                <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Class="nav-icon" />
                <span>Coupons</span>
            </a>
            <a class="nav-item" href="/admin/staff">
                <MudIcon Icon="@Icons.Material.Filled.ManageAccounts" Class="nav-icon" />
                <span>Staff</span>
            </a>
        </nav>

        <div class="sidebar-footer">
            <button class="logout-item">
                <MudIcon Icon="@Icons.Material.Filled.Logout" Class="nav-icon" />
                <span>Logout</span>
            </button>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="admin-main">

        <!-- GREETING CARD -->
        <div class="greeting-card glass-card">
            <div class="greeting-left">
                <span class="greeting-eyebrow">🌙 GOOD EVENING</span>
                <h1 class="greeting-title">Welcome back, Admin!</h1>
                <p class="greeting-sub">Monday, April 07, 2026</p>
            </div>
            <div class="greeting-badge">
                <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings"
                         Style="font-size: 2.8rem; color: rgba(255,255,255,0.85);" />
            </div>
        </div>

        <!-- STATS -->
        <p class="section-label">Overview</p>
        <div class="stats-grid">

            <div class="stat-card glass-card">
                <div class="stat-icon-wrap" style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber"
                             Style="color: white; font-size: 1.4rem;" />
                </div>
                <span class="stat-number">—</span>
                <span class="stat-label">Total Coupons</span>
            </div>

            <div class="stat-card glass-card">
                <div class="stat-icon-wrap" style="background: rgba(34,197,94,0.25);">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                             Style="color: #22c55e; font-size: 1.4rem;" />
                </div>
                <span class="stat-number">—</span>
                <span class="stat-label">Used Coupons</span>
            </div>

            <div class="stat-card glass-card">
                <div class="stat-icon-wrap" style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.People"
                             Style="color: white; font-size: 1.4rem;" />
                </div>
                <span class="stat-number">—</span>
                <span class="stat-label">Total Staff</span>
            </div>

            <div class="stat-card glass-card">
                <div class="stat-icon-wrap" style="background: rgba(234,179,8,0.25);">
                    <MudIcon Icon="@Icons.Material.Filled.School"
                             Style="color: #EAB308; font-size: 1.4rem;" />
                </div>
                <span class="stat-number">—</span>
                <span class="stat-label">Total Teachers</span>
            </div>

        </div>

        <!-- QUICK ACTIONS -->
        <p class="section-label">Quick Actions</p>
        <div class="actions-grid">

            <div class="action-card glass-card">
                <div class="action-icon-wrap" style="background: rgba(255,255,255,0.15);">
                    <MudIcon Icon="@Icons.Material.Filled.AddCard"
                             Style="color: white; font-size: 1.6rem;" />
                </div>
                <span class="action-title">Generate Coupon</span>
                <span class="action-sub">Create a one-time registration code</span>
                <div class="action-arrow">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward"
                             Style="color: rgba(255,255,255,0.5); font-size: 1.1rem;" />
                </div>
            </div>

            <div class="action-card glass-card">
                <div class="action-icon-wrap" style="background: rgba(234,179,8,0.25);">
                    <MudIcon Icon="@Icons.Material.Filled.ListAlt"
                             Style="color: #EAB308; font-size: 1.6rem;" />
                </div>
                <span class="action-title">View All Coupons</span>
                <span class="action-sub">Browse coupon usage and status</span>
                <div class="action-arrow">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward"
                             Style="color: rgba(255,255,255,0.5); font-size: 1.1rem;" />
                </div>
            </div>

            <div class="action-card glass-card">
                <div class="action-icon-wrap" style="background: rgba(34,197,94,0.25);">
                    <MudIcon Icon="@Icons.Material.Filled.ManageAccounts"
                             Style="color: #22c55e; font-size: 1.6rem;" />
                </div>
                <span class="action-title">Manage Staff</span>
                <span class="action-sub">Assign or revoke teacher roles</span>
                <div class="action-arrow">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward"
                             Style="color: rgba(255,255,255,0.5); font-size: 1.1rem;" />
                </div>
            </div>

        </div>
    </main>
</div>