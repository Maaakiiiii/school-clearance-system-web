@page "/profile"
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject StudentService StudentService

<div class="dash-page">
    <div class="bg-shapes">
        <div class="bg-shape bg-s1"></div>
        <div class="bg-shape bg-s2"></div>
        <div class="bg-shape bg-s3"></div>
    </div>

    <!-- STEADY SIDEBAR -->
    <div class="sidebar">
        <div class="sidebar-header">
            <img src="aclc_logo.png" alt="ACLC Logo" class="sidebar-logo" />
            <div class="sidebar-brand-wrap">
                <span class="sidebar-brand">School Clearance</span>
                <span class="sidebar-sub">Student Portal</span>
            </div>
        </div>
        <nav class="sidebar-nav">
            <div class="sidebar-nav-item" @onclick='() => NavigateTo("/dashboard")'>
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="sidebar-nav-icon" />
                <span>Dashboard</span>
            </div>
            <div class="sidebar-section-label">OFFICES</div>
            <div class="sidebar-nav-item" @onclick='() => NavigateTo("/registrar")'>
                <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Class="sidebar-nav-icon" />
                <span>Registrar Office</span>
            </div>
            <div class="sidebar-nav-item" @onclick='() => NavigateTo("/cashier")'>
                <MudIcon Icon="@Icons.Material.Filled.Payments" Class="sidebar-nav-icon" />
                <span>Cashier Office</span>
            </div>
            <div class="sidebar-nav-item" @onclick='() => NavigateTo("/grade-release")'>
                <MudIcon Icon="@Icons.Material.Filled.Grade" Class="sidebar-nav-icon" />
                <span>Grade Release</span>
            </div>
            <div class="sidebar-nav-item" @onclick='() => NavigateTo("/announcements")'>
                <MudIcon Icon="@Icons.Material.Filled.Campaign" Class="sidebar-nav-icon" />
                <span>Announcements</span>
            </div>
            <div class="sidebar-section-label">ACCOUNT</div>
            <div class="sidebar-nav-item active" @onclick='() => NavigateTo("/profile")'>
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="sidebar-nav-icon" />
                <span>Profile</span>
            </div>
            <div class="sidebar-nav-item" @onclick='() => NavigateTo("/settings")'>
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="sidebar-nav-icon" />
                <span>Settings</span>
            </div>
        </nav>
    </div>

    <!-- NAVBAR -->
    <div class="dash-navbar">
         <button class="hamburger-btn" @onclick="ToggleDrawer">
        <MudIcon Icon="@Icons.Material.Filled.Menu" Class="hamburger-icon" />
    </button>
        <div class="navbar-center">
            <div class="search-wrapper">
                <MudIcon Icon="@Icons.Material.Filled.Search" Class="search-icon" />
                <input placeholder="Search staff..." class="search-input" />
            </div>
        </div>
        <div class="navbar-right">
            <div class="notif-btn">
                <MudIcon Icon="@Icons.Material.Filled.Notifications" Class="notif-icon" />
            </div>
            <div class="nav-avatar" @onclick="ToggleProfileMenu">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="avatar-icon" />
            </div>
            @if (showProfileMenu)
            {
                <div style="position:fixed;inset:0;z-index:99;" @onclick="() => showProfileMenu = false"></div>
                <div class="profile-dropdown" style="z-index:100;">
                    <div class="profile-menu-item" @onclick="GoToProfile">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="profile-menu-icon" />
                        <span>Profile</span>
                    </div>
                    <div class="profile-menu-divider"></div>
                    <div class="profile-menu-item logout" @onclick="HandleLogout">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Class="profile-menu-icon" />
                        <span>Logout</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- MOBILE DRAWER OVERLAY -->
    @if (drawerOpen)
    {
        <div class="drawer-overlay" @onclick="CloseDrawer"></div>
    }

    <!-- MOBILE DRAWER -->
    <div class="side-drawer @(drawerOpen ? "drawer-open" : "")">
        <div class="drawer-header">
            <img src="aclc_logo.png" alt="ACLC Logo" class="drawer-logo" />
            <div class="drawer-brand-wrap">
                <span class="drawer-brand">School Clearance</span>
                <span class="drawer-sub">Student Portal</span>
            </div>
            <button class="drawer-close-btn" @onclick="CloseDrawer">
                <MudIcon Icon="@Icons.Material.Filled.Close" Class="drawer-close-icon" />
            </button>
        </div>
        <nav class="drawer-nav">
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/dashboard")'>
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="drawer-nav-icon" />
                <span>Dashboard</span>
            </div>
            <div class="drawer-section-label">OFFICES</div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/registrar")'>
                <MudIcon Icon="@Icons.Material.Filled.AssignmentInd" Class="drawer-nav-icon" />
                <span>Registrar Office</span>
            </div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/cashier")'>
                <MudIcon Icon="@Icons.Material.Filled.Payments" Class="drawer-nav-icon" />
                <span>Cashier Office</span>
            </div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/grade-release")'>
                <MudIcon Icon="@Icons.Material.Filled.Grade" Class="drawer-nav-icon" />
                <span>Grade Release</span>
            </div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/announcements")'>
                <MudIcon Icon="@Icons.Material.Filled.Campaign" Class="drawer-nav-icon" />
                <span>Announcements</span>
            </div>
            <div class="drawer-section-label">ACCOUNT</div>
            <div class="drawer-nav-item drawer-nav-active" @onclick='() => NavigateTo("/profile")'>
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="drawer-nav-icon" />
                <span>Profile</span>
            </div>
            <div class="drawer-nav-item" @onclick='() => NavigateTo("/settings")'>
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="drawer-nav-icon" />
                <span>Settings</span>
            </div>
        </nav>
    </div>

    <!-- PAGE CONTENT -->
    <div class="dash-content">

        <div class="profile-page-title">
            <MudText Typo="Typo.h4" Class="page-title-text">Profile</MudText>
            <MudText Typo="Typo.body1" Class="page-title-sub">Manage your personal information and account details.</MudText>
        </div>

        <!-- PROFILE CARD -->
        <div class="glass-card">
            <div class="profile-cover"></div>
            <div class="profile-card-body">
                <div class="profile-avatar-row">
                    <div class="profile-avatar" @onclick="OpenAvatarOptionsModal">
                        @if (profileImageUrl != null)
                        {
                            <img src="@profileImageUrl" alt="Profile" class="profile-img" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person" Class="profile-avatar-icon" />
                        }
                        <div class="avatar-overlay">
                            <MudIcon Icon="@Icons.Material.Filled.CameraAlt" Class="camera-icon" />
                            <span class="camera-label">Change</span>
                        </div>
                    </div>
                    <InputFile id="profileFileInput" OnChange="OnFileSelected" accept=".jpg,.jpeg,.png" style="display:none;" />
                    <div class="profile-header-actions">
                        <MudButton Variant="Variant.Outlined"
                                   Class="change-password-btn"
                                   StartIcon="@Icons.Material.Filled.Key"
                                   OnClick="TogglePasswordSection">
                            Change Password
                        </MudButton>
                    </div>
                </div>

                <div class="profile-identity">
                    <span class="profile-fullname">@fullName</span>
                    <div class="profile-chips-row">
                        <div class="profile-chip">
                            <MudIcon Icon="@Icons.Material.Filled.School" Class="chip-icon" />
                            <span>@course</span>
                        </div>
                        <div class="profile-chip">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Class="chip-icon" />
                            <span>@studentNo</span>
                        </div>
                        <div class="profile-chip">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Class="chip-icon" />
                            <span>@joinedDate</span>
                        </div>
                        <div class="profile-chip clearance-chip">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="chip-icon" />
                            <span>@clearedPercent% Cleared</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- PERSONAL INFORMATION -->
        <div class="glass-card">
            <div class="section-header">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="section-icon" />
                <MudText Typo="Typo.subtitle1" Class="section-label">PERSONAL INFORMATION</MudText>
            </div>

            @if (infoSaved)
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mb-4">
                    Information updated successfully!
                </MudAlert>
            }

            <div class="profile-form">
                <div class="profile-field-row">
                    <div class="profile-field">
                        <span class="profile-field-label">Department</span>
                        <MudSelect Value="@department"
                                   ValueChanged="@((string val) => OnDepartmentChanged(val))"
                                   Variant="Variant.Outlined"
                                   T="string"
                                   FullWidth="true">
                            <MudSelectItem Value="@("College")">College</MudSelectItem>
                            <MudSelectItem Value="@("Senior High School")">Senior High School</MudSelectItem>
                        </MudSelect>
                    </div>
                    <div class="profile-field">
                        <span class="profile-field-label">Course / Strand</span>
                        <MudSelect @bind-Value="course"
                                   Variant="Variant.Outlined"
                                   T="string"
                                   FullWidth="true"
                                   Disabled="@(string.IsNullOrEmpty(department))">
                            @foreach (var c in courseOptions)
                            {
                                <MudSelectItem Value="@c">@c</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                </div>
                <div class="profile-field">
                    <span class="profile-field-label">Year Level</span>
                    <MudSelect @bind-Value="yearLevel"
                               Variant="Variant.Outlined"
                               T="string"
                               FullWidth="true"
                               Disabled="@(string.IsNullOrEmpty(department))">
                        @foreach (var y in yearOptions)
                        {
                            <MudSelectItem Value="@y">@y</MudSelectItem>
                        }
                    </MudSelect>
                </div>

                <div class="profile-form-actions">
                    <MudButton Variant="Variant.Filled"
                               Class="profile-save-btn"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="ShowSaveConfirm"
                               Disabled="@isSavingInfo">
                        @if (isSavingInfo)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Save Changes</span>
                        }
                    </MudButton>
                </div>
            </div>
        </div>

        <!-- CLEARANCE SUMMARY -->
        <div class="glass-card">
            <div class="section-header">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="section-icon" />
                <MudText Typo="Typo.subtitle1" Class="section-label">CLEARANCE SUMMARY</MudText>
            </div>
            <div class="clearance-summary-grid">
                <div class="clearance-summary-item cleared">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="summary-icon" />
                    <span class="summary-count">@clearedCount</span>
                    <span class="summary-label">Cleared</span>
                </div>
                <div class="clearance-summary-item pending">
                    <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Class="summary-icon" />
                    <span class="summary-count">@pendingCount</span>
                    <span class="summary-label">Pending</span>
                </div>
                <div class="clearance-summary-item total">
                    <MudIcon Icon="@Icons.Material.Filled.ListAlt" Class="summary-icon" />
                    <span class="summary-count">@totalCount</span>
                    <span class="summary-label">Total</span>
                </div>
            </div>
        </div>

    </div>

    <!-- CHANGE PASSWORD MODAL -->
    @if (showPasswordSection)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);backdrop-filter:blur(4px);z-index:1000;" @onclick="ClosePasswordModal"></div>
        <div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1001;background:#1e2a45;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:2rem;width:100%;max-width:480px;box-shadow:0 24px 60px rgba(0,0,0,0.4);" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-title-row">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Class="modal-title-icon" />
                    <MudText Typo="Typo.subtitle1" Class="modal-title-text">CHANGE PASSWORD</MudText>
                </div>
                <button class="modal-close-btn" @onclick="ClosePasswordModal">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Class="modal-close-icon" />
                </button>
            </div>

            @if (!string.IsNullOrEmpty(passwordError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@passwordError</MudAlert>
            }
            @if (passwordSaved)
            {
                <MudAlert Severity="Severity.Success" Dense="true" Class="mb-4">Password changed successfully!</MudAlert>
            }

            <div class="profile-form">
                <div class="profile-field">
                    <span class="profile-field-label">Current Password</span>
                    <div class="custom-input-wrapper">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Class="custom-icon-left" />
                        <MudTextField @bind-Value="currentPassword"
                                      Variant="Variant.Outlined"
                                      InputType="@currentPwInput"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@currentPwIcon"
                                      OnAdornmentClick="ToggleCurrentPw"
                                      FullWidth="true"
                                      Class="custom-padded" />
                    </div>
                </div>
                <div class="profile-field">
                    <span class="profile-field-label">New Password</span>
                    <div class="custom-input-wrapper">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Class="custom-icon-left" />
                        <MudTextField @bind-Value="newPassword"
                                      Variant="Variant.Outlined"
                                      InputType="@newPwInput"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@newPwIcon"
                                      OnAdornmentClick="ToggleNewPw"
                                      FullWidth="true"
                                      Class="custom-padded" />
                    </div>
                </div>
                <div class="profile-field">
                    <span class="profile-field-label">Confirm New Password</span>
                    <div class="custom-input-wrapper">
                        <MudIcon Icon="@Icons.Material.Filled.Lock" Class="custom-icon-left" />
                        <MudTextField @bind-Value="confirmPassword"
                                      Variant="Variant.Outlined"
                                      InputType="@confirmPwInput"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@confirmPwIcon"
                                      OnAdornmentClick="ToggleConfirmPw"
                                      Error="@PasswordMismatch"
                                      ErrorText="Passwords do not match"
                                      FullWidth="true"
                                      Class="custom-padded" />
                    </div>
                </div>
                <div class="profile-form-actions">
                    <MudButton Variant="Variant.Filled"
                               Class="profile-save-btn"
                               StartIcon="@Icons.Material.Filled.Lock"
                               OnClick="SavePassword"
                               Disabled="@isSavingPassword">
                        @if (isSavingPassword)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Change Password</span>
                        }
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Class="profile-back-btn"
                               OnClick="ClosePasswordModal">
                        Cancel
                    </MudButton>
                </div>
            </div>
        </div>
    }

    <!-- SAVE INFO CONFIRMATION MODAL -->
    @if (showSaveConfirmModal)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);backdrop-filter:blur(4px);z-index:1000;" @onclick="CancelSaveInfo"></div>
        <div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1001;background:#1e2a45;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:2rem;width:100%;max-width:420px;box-shadow:0 24px 60px rgba(0,0,0,0.4);" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-title-row">
                    <MudIcon Icon="@Icons.Material.Filled.Save" Class="modal-title-icon" />
                    <MudText Typo="Typo.subtitle1" Class="modal-title-text">SAVE CHANGES</MudText>
                </div>
                <button class="modal-close-btn" @onclick="CancelSaveInfo">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Class="modal-close-icon" />
                </button>
            </div>
            <MudText style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:1.5rem;line-height:1.6;">
                Are you sure you want to save changes to your personal information?
            </MudText>
            <div class="profile-form-actions">
                <MudButton Variant="Variant.Filled"
                           Class="profile-save-btn"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="ConfirmSaveInfo">
                    Yes, Save
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Class="profile-back-btn"
                           OnClick="CancelSaveInfo">
                    Cancel
                </MudButton>
            </div>
        </div>
    }

    <!-- STEP 1: AVATAR OPTIONS MODAL (Change Photo / Remove) -->
    @if (showAvatarOptionsModal)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);backdrop-filter:blur(4px);z-index:1000;" @onclick="CloseAvatarOptionsModal"></div>
        <div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1001;background:#1e2a45;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:2rem;width:100%;max-width:380px;box-shadow:0 24px 60px rgba(0,0,0,0.4);" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-title-row">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="modal-title-icon" />
                    <MudText Typo="Typo.subtitle1" Class="modal-title-text">PROFILE PHOTO</MudText>
                </div>
                <button class="modal-close-btn" @onclick="CloseAvatarOptionsModal">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Class="modal-close-icon" />
                </button>
            </div>

            <div style="display:flex;justify-content:center;margin-bottom:1.5rem;">
                <div style="width:90px;height:90px;border-radius:50%;background:rgba(36,59,119,0.9);border:3px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;overflow:hidden;">
                    @if (profileImageUrl != null)
                    {
                        <img src="@profileImageUrl" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Person" style="font-size:44px;color:white;" />
                    }
                </div>
            </div>

            <div class="profile-form-actions" style="flex-direction:column;gap:10px;">
                <MudButton Variant="Variant.Filled"
                           Class="profile-save-btn"
                           StartIcon="@Icons.Material.Filled.CameraAlt"
                           OnClick="OpenFilePicker"
                           Style="width:100%;">
                    Change Profile Photo
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.Delete"
                           OnClick="RemoveProfilePicture"
                           Style="width:100%;color:rgba(255,80,80,0.85);border-color:rgba(255,80,80,0.4);text-transform:none;font-size:14px;font-weight:600;border-radius:10px;height:44px;">
                    Remove Profile Picture
                </MudButton>
            </div>
        </div>
    }

    <!-- STEP 2: PHOTO CONFIRM MODAL (after choosing a photo) -->
    @if (showPhotoConfirmModal)
    {
        <div style="position:fixed;inset:0;background:rgba(0,0,0,0.55);backdrop-filter:blur(4px);z-index:1000;" @onclick="CancelPhotoChange"></div>
        <div style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:1001;background:#1e2a45;border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:2rem;width:100%;max-width:380px;box-shadow:0 24px 60px rgba(0,0,0,0.4);" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-title-row">
                    <MudIcon Icon="@Icons.Material.Filled.CameraAlt" Class="modal-title-icon" />
                    <MudText Typo="Typo.subtitle1" Class="modal-title-text">USE THIS PHOTO?</MudText>
                </div>
                <button class="modal-close-btn" @onclick="CancelPhotoChange">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Class="modal-close-icon" />
                </button>
            </div>

            <div style="display:flex;justify-content:center;margin-bottom:1.2rem;">
                <img src="@pendingImageUrl" style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:3px solid rgba(255,255,255,0.2);" />
            </div>

            <MudText style="color:rgba(255,255,255,0.7);font-size:14px;margin-bottom:1.5rem;line-height:1.6;text-align:center;">
                Do you want to use this as your profile photo?
            </MudText>

            <div class="profile-form-actions" style="flex-direction:column;gap:10px;">
                <MudButton Variant="Variant.Filled"
                           Class="profile-save-btn"
                           StartIcon="@Icons.Material.Filled.Check"
                           OnClick="ConfirmPhotoChange"
                           Style="width:100%;">
                    Yes, Use This Photo
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Class="profile-back-btn"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="CancelPhotoChange"
                           Style="width:100%;">
                    Back
                </MudButton>
            </div>
        </div>
    }

</div>

@code {
    private string? profileImageUrl = null;
    private string? pendingImageUrl = null;
    private bool drawerOpen = false;
    private bool showPasswordSection = false;
    private bool showProfileMenu = false;
    private bool showSaveConfirmModal = false;
    private bool showAvatarOptionsModal = false;
    private bool showPhotoConfirmModal = false;

    private string fullName = "";
    private string studentNo = "";
    private string joinedDate = "";
    private int clearedPercent = 0;
    private int clearedCount = 0;
    private int pendingCount = 0;
    private int totalCount = 0;

    private string department = "";
    private string course = "";
    private string yearLevel = "";
    private bool isSavingInfo = false;
    private bool infoSaved = false;

    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private bool showCurrentPw = false;
    private bool showNewPw = false;
    private bool showConfirmPw = false;
    private bool isSavingPassword = false;
    private bool passwordSaved = false;
    private string passwordError = "";

    private List<string> courseOptions = new();
    private List<string> yearOptions = new();

    protected override async Task OnInitializedAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");
        var studentIdStr = await JS.InvokeAsync<string>("localStorage.getItem", "studentId");
        int.TryParse(studentIdStr, out int studentId);

        var result = await StudentService.GetProfile(studentId, token);
        if (result?.Status == 1 && result.Data != null)
        {
            fullName = result.Data.FullName ?? "";
            studentNo = result.Data.StudentNo ?? "";
            department = result.Data.Department ?? "";
            course = result.Data.CourseStrand ?? "";
            yearLevel = result.Data.YearLevel ?? "";
            joinedDate = "Joined " + result.Data.CreatedAt.ToString("MMM yyyy");

            if (department == "College")
            {
                courseOptions = new() { "BS Information Technology", "BS Computer Science", "BS Business Administration", "BS Accountancy", "BS Hospitality Management", "BS Tourism Management" };
                yearOptions = new() { "1st Year", "2nd Year", "3rd Year", "4th Year" };
            }
            else if (department == "Senior High School")
            {
                courseOptions = new() { "ABM", "HUMSS", "STEM", "TVL", "GAS" };
                yearOptions = new() { "Grade 11", "Grade 12" };
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedPhoto = await JS.InvokeAsync<string>("localStorage.getItem", "profileImageUrl");
            if (!string.IsNullOrEmpty(savedPhoto))
            {
                profileImageUrl = savedPhoto;
                StateHasChanged();
            }
        }
    }

    private void OpenAvatarOptionsModal() => showAvatarOptionsModal = true;
    private void CloseAvatarOptionsModal() => showAvatarOptionsModal = false;

    private async Task OpenFilePicker()
    {
        showAvatarOptionsModal = false;
        await JS.InvokeVoidAsync("eval", "document.getElementById('profileFileInput').click()");
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        var buffer = new byte[file.Size];
        await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        pendingImageUrl = $"data:{file.ContentType};base64,{base64}";
        showPhotoConfirmModal = true;
    }

    private async Task ConfirmPhotoChange()
    {
        profileImageUrl = pendingImageUrl;
        pendingImageUrl = null;
        showPhotoConfirmModal = false;
        await JS.InvokeVoidAsync("localStorage.setItem", "profileImageUrl", profileImageUrl);
    }

    private void CancelPhotoChange()
    {
        pendingImageUrl = null;
        showPhotoConfirmModal = false;
    }

    private async Task RemoveProfilePicture()
    {
        profileImageUrl = null;
        pendingImageUrl = null;
        showAvatarOptionsModal = false;
        await JS.InvokeVoidAsync("localStorage.removeItem", "profileImageUrl");
    }

    private void OnDepartmentChanged(string val)
    {
        department = val;
        course = "";
        yearLevel = "";
        if (val == "College")
        {
            courseOptions = new() { "BS Information Technology", "BS Computer Science", "BS Business Administration", "BS Accountancy", "BS Hospitality Management", "BS Tourism Management" };
            yearOptions = new() { "1st Year", "2nd Year", "3rd Year", "4th Year" };
        }
        else
        {
            courseOptions = new() { "ABM", "HUMSS", "STEM", "TVL", "GAS" };
            yearOptions = new() { "Grade 11", "Grade 12" };
        }
    }

    private void ShowSaveConfirm() => showSaveConfirmModal = true;
    private void CancelSaveInfo() => showSaveConfirmModal = false;

    private async Task ConfirmSaveInfo()
    {
        showSaveConfirmModal = false;
        isSavingInfo = true;
        infoSaved = false;
        await Task.Delay(600);
        isSavingInfo = false;
        infoSaved = true;
    }

    private bool PasswordMismatch => !string.IsNullOrEmpty(confirmPassword) && newPassword != confirmPassword;

    private InputType currentPwInput => showCurrentPw ? InputType.Text : InputType.Password;
    private string currentPwIcon => showCurrentPw ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private InputType newPwInput => showNewPw ? InputType.Text : InputType.Password;
    private string newPwIcon => showNewPw ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private InputType confirmPwInput => showConfirmPw ? InputType.Text : InputType.Password;
    private string confirmPwIcon => showConfirmPw ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private void ToggleCurrentPw() => showCurrentPw = !showCurrentPw;
    private void ToggleNewPw() => showNewPw = !showNewPw;
    private void ToggleConfirmPw() => showConfirmPw = !showConfirmPw;

    private void TogglePasswordSection()
    {
        showPasswordSection = !showPasswordSection;
        if (!showPasswordSection) ResetPasswordFields();
    }

    private void ClosePasswordModal()
    {
        showPasswordSection = false;
        ResetPasswordFields();
    }

    private void ResetPasswordFields()
    {
        currentPassword = "";
        newPassword = "";
        confirmPassword = "";
        passwordError = "";
        passwordSaved = false;
        showCurrentPw = false;
        showNewPw = false;
        showConfirmPw = false;
    }

    private void ToggleDrawer() => drawerOpen = !drawerOpen;
    private void CloseDrawer() => drawerOpen = false;
    private void ToggleProfileMenu() => showProfileMenu = !showProfileMenu;

    private void NavigateTo(string url) { drawerOpen = false; Navigation.NavigateTo(url); }
    private void GoToProfile() { showProfileMenu = false; Navigation.NavigateTo("/profile"); }
    private void HandleLogout() { showProfileMenu = false; Navigation.NavigateTo("/loginpage"); }

    private async Task SavePassword()
    {
        passwordError = "";
        passwordSaved = false;
        if (string.IsNullOrWhiteSpace(currentPassword)) { passwordError = "Current password is required."; return; }
        if (newPassword.Length < 8) { passwordError = "New password must be at least 8 characters."; return; }
        if (PasswordMismatch) { passwordError = "Passwords do not match."; return; }
        isSavingPassword = true;
        await Task.Delay(600);
        isSavingPassword = false;
        passwordSaved = true;
        await Task.Delay(1200);
        ClosePasswordModal();
    }
}
